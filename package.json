{
  "author": {
    "email": "milev.stefan@gmail.com",
    "name": "Delemangi",
    "url": "https://delemangi.com"
  },
  "bugs": {
    "url": "https://github.com/finki-hub/finki-auth/issues"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "fetch-cookie": "^3.2.0",
    "tough-cookie": "^6.0.1",
    "zod": "^4.4.3"
  },
  "description": "Authentication for FCSE services",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-config-imperium": "^4.1.3",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "typescript": "~7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^24 || ^26"
  },
  "files": [
    "dist",
    "!**/*.test.*",
    "!**/tests"
  ],
  "homepage": "https://github.com/finki-hub/finki-auth",
  "keywords": [
    "finki",
    "auth",
    "authentication"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "finki-auth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finki-hub/finki-auth.git"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "format": "eslint --ignore-pattern \"**/test/*\" --fix .",
    "lint": "tsc --noEmit && eslint . --ignore-pattern \"**/test/*\" --no-warn-ignored --cache",
    "prepare": "husky",
    "package": "npm run build && npm pack",
    "release": "npm run build && semantic-release",
    "release:dry": "npm run build && npm run release -- --dry-run",
    "test": "vitest run --exclude dist"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "0.0.0"
}
